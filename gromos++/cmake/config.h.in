/* config.h - generated by CMake from cmake/config.h.in */
#pragma once

/* Gromos version */
#define GROMOS_VERSION "@GROMOS_VERSION@"
#define GROMOS_MAJOR_VERSION @GROMOS_MAJOR_VERSION@
#define GROMOS_MINOR_VERSION @GROMOS_MINOR_VERSION@
#define GROMOS_MICRO_VERSION @GROMOS_MICRO_VERSION@
#define GROMOS_DATE "@GROMOS_DATE@"

/* Compiler */
#cmakedefine COMPILER_ICC 1
#cmakedefine COMPILER_GCC 1

/* Required libraries */
#cmakedefine HAVE_GSL 1

/* Optional libraries */
#cmakedefine HAVE_CLIPPER 1
#cmakedefine HAVE_MDPP 1
#cmakedefine GROMOSXX
#cmakedefine HAVE_GMX 1
#cmakedefine HAVE_VMD 1

/* FFTW prefix: fftw_ (no clipper) or fftw3_ (with clipper) */
#define FFTW_PREFIX @FFTW_PREFIX@

/* Optional headers and functions */
#cmakedefine HAVE_READLINE 1
#cmakedefine HAVE_WORDEXP_H 1
#cmakedefine HAVE_WORDEXP 1
#cmakedefine HAVE_WORDFREE 1

/* Math functions */
#cmakedefine HAVE_HYPOT 1
#cmakedefine HAVE_EXPM1 1
#cmakedefine HAVE_ACOSH 1
#cmakedefine HAVE_ASINH 1
#cmakedefine HAVE_ATANH 1
#cmakedefine HAVE_ISINF 1
#cmakedefine HAVE_FINITE 1
#cmakedefine HAVE_ISFINITE 1
#cmakedefine HAVE_ISNAN 1
#cmakedefine HAVE_LOG1P 1
